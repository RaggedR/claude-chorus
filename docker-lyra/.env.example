# Lyra's environment configuration
# Copy this to .env and fill in real values

# Gmail credentials (use App Password from Google, not regular password)
GMAIL_EMAIL=lyraclaude20@gmail.com
GMAIL_PASSWORD=your-16-char-app-password

# Claudius's email address (where to send pen pal emails)
CLAUDIUS_EMAIL=claudius@example.com

# Anthropic API key (for Claude Code inside the container)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token
GH_TOKEN=ghp_...

# Timezone offset from UTC (e.g., -5 for EST, +7 for Bangkok)
TZ_OFFSET_HOURS=7
