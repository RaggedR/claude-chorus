# Clio's environment variables
# Copy to .env and fill in values

# Gmail (app-specific password)
GMAIL_EMAIL=
GMAIL_PASSWORD=

# GitHub token (for gh CLI) — optional, add when she has an account
# GH_TOKEN=
# GH_EMAIL=

# Cycles per day (default 2)
CYCLES_PER_DAY=2

# Gap between sessions in hours (default 2)
GAP_HOURS=2
